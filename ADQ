<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Adquisiciones 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:       #F7F6F2;
  --surface:  #FFFFFF;
  --surface2: #F0EEE8;
  --border:   rgba(0,0,0,0.09);
  --border2:  rgba(0,0,0,0.18);
  --t1:       #111110;
  --t2:       #605F5A;
  --t3:       #999892;
  --accent:   #3B5BDB;
  --r:        10px;
  --shadow:   0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.05);
  --shadow2:  0 4px 16px rgba(0,0,0,0.08);
}

@media (prefers-color-scheme: dark) {
  :root {
    --bg:       #121211;
    --surface:  #1C1C1A;
    --surface2: #242422;
    --border:   rgba(255,255,255,0.08);
    --border2:  rgba(255,255,255,0.16);
    --t1:       #EDEAE2;
    --t2:       #9B9890;
    --t3:       #666460;
    --accent:   #748FFC;
    --shadow:   0 1px 3px rgba(0,0,0,0.3);
    --shadow2:  0 4px 16px rgba(0,0,0,0.4);
  }
  .bs0 { background: #2A2A28; color: #CCCAC0; }
  .bs1 { background: #21205A; color: #C8C4F8; }
  .bs2 { background: #082C52; color: #90C4F0; }
  .bs3 { background: #162F04; color: #A8D470; }
  .bs4 { background: #3A2002; color: #F5B860; }
  .bs5 { background: #481212; color: #F2AEAE; }
  .bs6 { background: #2A2A28; color: #CCCAC0; }
  .bs7 { background: #481212; color: #F2AEAE; }
  .tag-si  { background: #162F04; color: #A8D470; }
  .tag-no  { background: #2A2A28; color: #9B9890; }
  .dias-rojo   { background: #481212; color: #F2AEAE; }
  .dias-naranja{ background: #3A2002; color: #F5B860; }
  .dias-verde  { background: #162F04; color: #A8D470; }
  .dias-gris   { background: #2A2A28; color: #CCCAC0; }
}

body {
  font-family: 'DM Sans', system-ui, sans-serif;
  background: var(--bg);
  color: var(--t1);
  min-height: 100vh;
  font-size: 14px;
  line-height: 1.5;
}

/* ── Header ── */
header {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0 1.5rem;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--shadow);
}
.header-left { display: flex; align-items: center; gap: 16px; }
header h1 { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
.header-badge {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  color: var(--t3);
  background: var(--surface2);
  padding: 2px 8px;
  border-radius: 20px;
}
.sync-btn {
  display: flex; align-items: center; gap: 7px;
  padding: 6px 14px; font-size: 12px; font-weight: 500;
  border: 1px solid var(--border2); border-radius: 8px;
  background: var(--surface); color: var(--t2);
  cursor: pointer; transition: all .15s; font-family: inherit;
}
.sync-btn:hover { background: var(--surface2); color: var(--t1); }
.sync-dot {
  width: 7px; height: 7px; border-radius: 50%; background: #4C9A2A; flex-shrink: 0;
  transition: background .3s;
}
.sync-dot.syncing { background: #EF9F27; animation: pulse 1s infinite; }
.sync-dot.error   { background: #E24B4A; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .25; } }

/* ── Layout ── */
.container { max-width: 1340px; margin: 0 auto; padding: 1.5rem; }

/* ── Tabs ── */
.tabs {
  display: flex; gap: 2px; margin-bottom: 1.75rem;
  border-bottom: 1px solid var(--border);
}
.tab {
  padding: 9px 18px; font-size: 13px; font-weight: 500; font-family: inherit;
  cursor: pointer; border: none; background: none; color: var(--t2);
  border-bottom: 2px solid transparent; margin-bottom: -1px;
  transition: color .15s; border-radius: 4px 4px 0 0;
}
.tab:hover { color: var(--t1); }
.tab.active { color: var(--t1); border-bottom-color: var(--accent); }

/* ── Metrics ── */
.metric-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 12px; margin-bottom: 1.5rem;
}
.metric {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 1rem 1.125rem;
  box-shadow: var(--shadow); transition: box-shadow .15s;
}
.metric:hover { box-shadow: var(--shadow2); }
.metric-label { font-size: 11px; font-weight: 500; color: var(--t3); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }
.metric-value { font-size: 24px; font-weight: 600; letter-spacing: -0.02em; line-height: 1; }
.metric-sub { font-size: 11px; color: var(--t3); margin-top: 4px; }

/* ── Cards ── */
.card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 1.125rem 1.25rem;
  box-shadow: var(--shadow);
}
.card-full { margin-bottom: 1.25rem; }
.card-title { font-size: 12px; font-weight: 600; color: var(--t2); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 14px; }
.charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 1.25rem; }

/* ── Progress bars ── */
.prog-gen-track {
  height: 20px; background: var(--surface2); border-radius: 10px;
  overflow: hidden; display: flex; margin-bottom: 10px;
}
.prog-seg { height: 100%; transition: width .4s ease; }
.prog-legend { display: flex; flex-wrap: wrap; gap: 8px 14px; }
.prog-legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--t2); }
.prog-dot { width: 9px; height: 9px; border-radius: 2px; flex-shrink: 0; }
.prog-single { margin-bottom: 10px; }
.prog-header { display: flex; justify-content: space-between; margin-bottom: 4px; }
.prog-name  { font-size: 12px; color: var(--t2); font-weight: 500; }
.prog-pct   { font-size: 11px; color: var(--t3); font-family: 'DM Mono', monospace; }
.prog-track { height: 8px; background: var(--surface2); border-radius: 4px; overflow: hidden; }
.prog-fill  { height: 100%; border-radius: 4px; transition: width .5s ease; }

/* ── Bar chart ── */
.bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.bar-label {
  font-size: 11px; color: var(--t2); width: 120px; text-align: right;
  flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.bar-track { flex: 1; height: 12px; background: var(--surface2); border-radius: 6px; overflow: hidden; }
.bar-fill  { height: 100%; border-radius: 6px; transition: width .4s ease; }
.bar-count { font-size: 11px; color: var(--t2); width: 24px; text-align: right; flex-shrink: 0; font-family: 'DM Mono', monospace; }

/* ── Próximas aperturas table ── */
.urg-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.urg-table th { text-align: left; padding: 8px 10px; color: var(--t2); font-weight: 500; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: .04em; }
.urg-table td { padding: 9px 10px; border-bottom: 1px solid var(--border); vertical-align: middle; }
.urg-table tr:last-child td { border-bottom: none; }
.urg-table tbody tr:hover td { background: var(--surface2); }

/* ── Días chips ── */
.dias-chip { display: inline-block; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 20px; white-space: nowrap; font-family: 'DM Mono', monospace; }
.dias-rojo    { background: #FCEAEA; color: #A32D2D; }
.dias-naranja { background: #FEF0DA; color: #7A4002; }
.dias-verde   { background: #E8F5D8; color: #2D5A0C; }
.dias-gris    { background: var(--surface2); color: var(--t3); }

/* ── Badges de estado ── */
.badge { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; font-weight: 600; white-space: nowrap; }
.bs0 { background: #EEECEA; color: #52504C; }
.bs1 { background: #EDEEFE; color: #3530A0; }
.bs2 { background: #E2EEF9; color: #0C4480; }
.bs3 { background: #E6F4D4; color: #2B580C; }
.bs4 { background: #FEF3DA; color: #7A4002; }
.bs5 { background: #FCEAEA; color: #881E1E; }
.bs6 { background: #EEECEA; color: #706E6A; }
.bs7 { background: #FCEAEA; color: #A32D2D; }

/* ── Proyectos accordion ── */
.proy-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); margin-bottom: 10px; overflow: hidden;
  box-shadow: var(--shadow); transition: box-shadow .15s;
}
.proy-card:hover { box-shadow: var(--shadow2); }
.proy-header {
  padding: .9rem 1.25rem; cursor: pointer;
  display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
}
.proy-header:hover { background: var(--surface2); }
.proy-name { font-size: 14px; font-weight: 600; }
.proy-hospitals { font-size: 11px; color: var(--t3); margin-top: 2px; }
.proy-badges { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; align-items: center; }
.proy-meta { display: flex; align-items: center; gap: 10px; flex-shrink: 0; margin-top: 2px; }
.proy-count { font-size: 11px; color: var(--t2); background: var(--surface2); padding: 2px 8px; border-radius: 20px; border: 1px solid var(--border); }
.proy-monto { font-size: 13px; font-weight: 600; font-family: 'DM Mono', monospace; }
.proy-arrow { font-size: 11px; color: var(--t3); transition: transform .2s; margin-top: 3px; }
.proy-arrow.open { transform: rotate(90deg); }
.proy-body { display: none; border-top: 1px solid var(--border); overflow-x: auto; }
.proy-body.open { display: block; }
.proy-table { width: 100%; border-collapse: collapse; font-size: 12px; min-width: 680px; }
.proy-table th { padding: 7px 10px; font-size: 10px; color: var(--t2); font-weight: 600; text-transform: uppercase; letter-spacing: .04em; background: var(--surface2); text-align: left; border-bottom: 1px solid var(--border); }
.proy-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); }
.proy-table tr:last-child td { border-bottom: none; }
.proy-table tr:hover td { background: var(--surface2); }

/* ── Equipos table ── */
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; flex-wrap: wrap; gap: 8px; }
.section-title { font-size: 15px; font-weight: 600; }
.filters { display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
.filters input, .filters select {
  font-family: 'DM Sans', sans-serif; font-size: 13px;
  padding: 7px 11px; border: 1px solid var(--border2); border-radius: 8px;
  background: var(--surface); color: var(--t1); outline: none;
  transition: border-color .15s;
}
.filters input:focus, .filters select:focus { border-color: var(--accent); }
.filters input { flex: 1; min-width: 200px; }
.total-bar {
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--r);
  padding: .7rem 1rem; margin-bottom: 12px; display: flex; align-items: baseline;
  gap: 10px; flex-wrap: wrap; box-shadow: var(--shadow);
}
.total-label { font-size: 12px; color: var(--t3); font-weight: 500; }
.total-value { font-size: 18px; font-weight: 600; letter-spacing: -0.01em; font-family: 'DM Mono', monospace; }
.total-sub { font-size: 12px; color: var(--t3); }
.table-wrap { overflow-x: auto; border-radius: var(--r); box-shadow: var(--shadow); }
table.main {
  width: 100%; border-collapse: collapse; font-size: 12px; min-width: 1020px;
  background: var(--surface);
}
table.main th {
  text-align: left; padding: 9px 11px; color: var(--t2); font-weight: 600; font-size: 10px;
  text-transform: uppercase; letter-spacing: .04em; border-bottom: 1px solid var(--border);
  background: var(--surface2); position: sticky; top: 0; z-index: 1; white-space: nowrap;
}
table.main td { padding: 8px 11px; border-bottom: 1px solid var(--border); vertical-align: middle; }
table.main tr:last-child td { border-bottom: none; }
table.main tbody tr:hover td { background: var(--surface2); transition: background .1s; }
.tag-cheq { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; font-weight: 600; }
.tag-si { background: #E6F4D4; color: #2B580C; }
.tag-no { background: var(--surface2); color: var(--t3); }
.empty { text-align: center; padding: 3.5rem; color: var(--t3); font-size: 13px; }

/* ── Loading ── */
.loading-screen {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 5rem 2rem; gap: 12px; text-align: center;
}
.loading-spinner {
  width: 32px; height: 32px; border: 2px solid var(--border2);
  border-top-color: var(--accent); border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-title { font-size: 14px; font-weight: 500; color: var(--t2); }
.loading-sub { font-size: 12px; color: var(--t3); }

/* ── Debug panel ── */
.debug-panel {
  background: var(--surface2); border: 1px solid var(--border); border-radius: var(--r);
  padding: 12px 14px; margin-bottom: 14px; font-size: 11px; font-family: 'DM Mono', monospace;
  color: var(--t2); line-height: 1.8;
}
.debug-panel summary { cursor: pointer; font-weight: 600; color: var(--t1); list-style: none; }
.debug-panel summary::before { content: '▶  '; }
.debug-panel[open] summary::before { content: '▼  '; }
.debug-val { color: var(--accent); }


/* ── Multi-select filters ── */
.ms-wrap { position: relative; display: inline-block; }
.ms-btn {
  display: flex; align-items: center; gap: 6px; padding: 7px 11px;
  font-family: 'DM Sans', sans-serif; font-size: 13px;
  border: 1px solid var(--border2); border-radius: 8px;
  background: var(--surface); color: var(--t1); cursor: pointer;
  white-space: nowrap; transition: border-color .15s;
  user-select: none;
}
.ms-btn:hover { border-color: var(--accent); }
.ms-btn.has-sel { border-color: var(--accent); color: var(--accent); }
.ms-count {
  background: var(--accent); color: #fff; border-radius: 20px;
  font-size: 10px; font-weight: 700; padding: 1px 6px; min-width: 18px;
  text-align: center;
}
.ms-panel {
  display: none; position: absolute; top: calc(100% + 4px); left: 0;
  background: var(--surface); border: 1px solid var(--border2); border-radius: var(--r);
  box-shadow: var(--shadow2); z-index: 200; min-width: 200px; max-width: 300px;
  max-height: 260px; overflow-y: auto; padding: 6px 0;
}
.ms-panel.open { display: block; }
.ms-item {
  display: flex; align-items: center; gap: 8px; padding: 6px 12px;
  font-size: 13px; cursor: pointer; transition: background .1s;
}
.ms-item:hover { background: var(--surface2); }
.ms-item input[type=checkbox] { accent-color: var(--accent); width: 14px; height: 14px; flex-shrink: 0; cursor: pointer; }
.ms-item label { cursor: pointer; flex: 1; line-height: 1.3; }
.ms-sep { height: 1px; background: var(--border); margin: 4px 0; }
.ms-clear { padding: 5px 12px; font-size: 11px; color: var(--accent); cursor: pointer; font-weight: 500; }
.ms-clear:hover { text-decoration: underline; }
.active-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; min-height: 0; }
.active-chip {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 8px 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 500;
  background: var(--accent); color: #fff; cursor: default;
}
.chip-x { cursor: pointer; font-size: 13px; line-height: 1; opacity: .8; }
.chip-x:hover { opacity: 1; }

/* ── Distribución tab ── */
.dist-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); margin-bottom: 10px; overflow: hidden;
  box-shadow: var(--shadow); transition: box-shadow .15s;
}
.dist-card:hover { box-shadow: var(--shadow2); }
.dist-header {
  padding: .9rem 1.25rem; cursor: pointer;
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
}
.dist-header:hover { background: var(--surface2); }
.dist-name { font-size: 14px; font-weight: 600; flex: 1; }
.dist-meta { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
.dist-hosp-count { font-size: 11px; color: var(--t2); background: var(--surface2); padding: 2px 8px; border-radius: 20px; border: 1px solid var(--border); }
.dist-qty { font-size: 13px; font-weight: 700; font-family: 'DM Mono', monospace; color: var(--accent); }
.dist-monto { font-size: 12px; font-family: 'DM Mono', monospace; color: var(--t2); }
.dist-body { display: none; border-top: 1px solid var(--border); overflow-x: auto; }
.dist-body.open { display: block; }
.dist-table { width: 100%; border-collapse: collapse; font-size: 12px; min-width: 580px; }
.dist-table th { padding: 7px 10px; font-size: 10px; color: var(--t2); font-weight: 600; text-transform: uppercase; letter-spacing: .04em; background: var(--surface2); text-align: left; border-bottom: 1px solid var(--border); }
.dist-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); }
.dist-table tr:last-child td { border-bottom: none; }
.dist-table tr:hover td { background: var(--surface2); }
.dist-qty-cell { font-weight: 700; font-family: 'DM Mono', monospace; color: var(--accent); text-align: center; }

/* ── Misc ── */
@media (max-width: 720px) {
  .charts-grid { grid-template-columns: 1fr; }
  .metric-grid { grid-template-columns: 1fr 1fr; }
}
</style>
</head>
<body>

<header>
  <div class="header-left">
    <h1>Adquisiciones 2026</h1>
    <span class="header-badge" id="header-count">—</span>
  </div>
  <button class="sync-btn" id="sync-btn" onclick="cargarDatos(true)">
    <div class="sync-dot" id="sync-dot"></div>
    <span id="sync-label">Actualizar</span>
  </button>
</header>

<div class="container">

  <!-- Loading -->
  <div id="loading-screen" class="loading-screen">
    <div class="loading-spinner"></div>
    <div class="loading-title">Cargando datos desde Google Sheets</div>
    <div class="loading-sub">Esto puede tardar unos segundos…</div>
  </div>

  <!-- App -->
  <div id="app" style="display:none">

    <div class="tabs">
      <button class="tab active" onclick="showTab('dashboard')">Dashboard</button>
      <button class="tab" onclick="showTab('proyectos')">Por proyecto</button>
      <button class="tab" onclick="showTab('equipos')">Equipos</button>
      <button class="tab" onclick="showTab('distribucion')">Distribución</button>
    </div>

    <!-- ══════════════ DASHBOARD ══════════════ -->
    <div id="tab-dashboard">
      <div class="metric-grid" id="metrics"></div>

      <div class="card card-full">
        <div class="card-title">Progreso general del plan 2026</div>
        <div class="prog-gen-track" id="prog-gen"></div>
        <div class="prog-legend" id="prog-legend"></div>
      </div>

      <div class="card card-full">
        <div class="card-title">Avance por estado</div>
        <div id="prog-estados"></div>
      </div>

      <div class="charts-grid">
        <div class="card"><div class="card-title">Por hospital (top 10)</div><div id="ch-hosp"></div></div>
        <div class="card"><div class="card-title">Por tipo de proyecto</div><div id="ch-tipo"></div></div>
      </div>

      <div class="card card-full">
        <div class="card-title">Próximas aperturas</div>
        <div id="ch-apertura"></div>
      </div>
    </div>

    <!-- ══════════════ PROYECTOS ══════════════ -->
    <div id="tab-proyectos" style="display:none">
      <div class="section-header">
        <div class="section-title">Agrupado por proyecto</div>
        <div id="proy-total" style="font-size:13px;color:var(--t2)"></div>
      </div>
      <div id="proy-container"></div>
    </div>

    <!-- ══════════════ EQUIPOS ══════════════ -->
    <div id="tab-equipos" style="display:none">
      <div class="section-header">
        <div class="section-title">Equipos registrados</div>
        <div style="font-size:12px;color:var(--t3)">Los datos se editan en Google Sheets</div>
      </div>

      <!-- Panel de diagnóstico de estados -->
      <details class="debug-panel" id="debug-estados" style="display:none">
        <summary>Diagnóstico de columna ESTADO</summary>
        <div id="debug-content"></div>
      </details>

      <div class="filters" id="filters-row">
        <input type="text" id="search" placeholder="Buscar equipo, hospital, proyecto…" oninput="renderTabla()" style="max-width:260px">
        <div class="ms-wrap" id="ms-wrap-estado"><button class="ms-btn" id="ms-btn-estado" onclick="toggleMs('estado',event)">Estado <span class="ms-count" id="ms-cnt-estado" style="display:none">0</span></button><div class="ms-panel" id="ms-panel-estado"></div></div>
        <div class="ms-wrap" id="ms-wrap-hosp"><button class="ms-btn" id="ms-btn-hosp" onclick="toggleMs('hosp',event)">Hospital <span class="ms-count" id="ms-cnt-hosp" style="display:none">0</span></button><div class="ms-panel" id="ms-panel-hosp"></div></div>
