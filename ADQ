<script>
// ═══════════════════════════════════════════════════
//  CONFIGURACIÓN
// ═══════════════════════════════════════════════════
var API_URL = 'https://script.google.com/macros/s/AKfycbzD-hJkihX-7wLb4DqUfGCYtIYRWEc2VdziaJ5h0EbMnZhCZAaKx67aoCCLY-Os7jD3/exec';

// ── Estados conocidos con sus colores y orden de avance ──
// Podés agregar más acá si querés un color específico.
// Cualquier estado que aparezca en el Sheet pero NO esté acá
// se agrega automáticamente con un color de la paleta extra.
var ESTADOS_BASE = [
  { v:'SIN AVANCE',       cls:'bs0', color:'#9B9890' },
  { v:'ARMADO DE PLIEGO', cls:'bs1', color:'#7C74E8' },
  { v:'PUBLICACION',      cls:'bs2', color:'#3D87D8' },
  { v:'EN EVALUACION',    cls:'bs4', color:'#EF9F27' },
  { v:'ADJUDICADO',       cls:'bs3', color:'#5A9E1A' },
  { v:'FRACASADO',        cls:'bs5', color:'#E24B4A' },
  { v:'DESIERTO',         cls:'bs6', color:'#B0AEA7' },
  { v:'NO SE COMPRO',     cls:'bs7', color:'#A32D2D' }
];

// Colores extra para estados no previstos que aparezcan en el Sheet
var COLORES_EXTRA = [
  '#1D9E75','#C879D8','#D87B3D','#3DB8B8','#8B5E3C',
  '#D43D7A','#4A90D9','#7B8D42','#9B59B6','#E67E22'
];

// Se construyen dinámicamente al cargar datos
var ESTADOS      = ESTADOS_BASE.slice();
var ESTADO_MAP   = {};
var ESTADOS_VALIDOS = {};

function reconstruirEstadoMap() {
  ESTADO_MAP = {};
  ESTADOS_VALIDOS = {};
  ESTADOS.forEach(function(e) {
    ESTADO_MAP[e.v]      = e;
    ESTADOS_VALIDOS[e.v] = true;
  });
}
reconstruirEstadoMap();

var TIPO_COLOR = { 'OBRA':'#3D87D8','SUMAR':'#1D9E75','SOLO PROYECTO':'#EF9F27','2027':'#9B9890' };

// ═══════════════════════════════════════════════════
//  ESTADO: data global
// ═══════════════════════════════════════════════════
var agrupados = [];
var rawCount  = 0;
var rawEstadosMuestra = []; // para debug

// ═══════════════════════════════════════════════════
//  HELPERS
// ═══════════════════════════════════════════════════
function parseUSD(val) {
  if (!val && val !== 0) return 0;
  if (typeof val === 'number') return isNaN(val) ? 0 : val;
  var n = parseFloat(String(val).replace(/[^0-9.]/g,''));
  return isNaN(n) ? 0 : n;
}
function fmtUSD(n) {
  if (!n) return '—';
  return 'USD ' + n.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
}
function fmtFecha(s) {
  if (!s) return '—';
  var p = s.split('-');
  return p.length === 3 ? p[2]+'/'+p[1]+'/'+p[0] : s;
}
function diasChip(f) {
  if (!f) return '';
  var hoy = new Date(); hoy.setHours(0,0,0,0);
  var d   = Math.ceil((new Date(f+'T00:00:00') - hoy) / 86400000);
  if (d < 0)  return '<span class="dias-chip dias-gris">Vencida</span>';
  if (d === 0) return '<span class="dias-chip dias-rojo">Hoy</span>';
  if (d <= 7)  return '<span class="dias-chip dias-rojo">'+d+'d</span>';
  if (d <= 30) return '<span class="dias-chip dias-naranja">'+d+'d</span>';
  return '<span class="dias-chip dias-verde">'+d+'d</span>';
}
function badge(e) {
  var info = ESTADO_MAP[e] || ESTADO_MAP['SIN AVANCE'];
  return '<span class="badge '+info.cls+'">'+(e||'SIN AVANCE')+'</span>';
}

// ═══════════════════════════════════════════════════
//  LECTURA DE ESTADO — normalización robusta + acentos
// ═══════════════════════════════════════════════════

// Quita acentos: COMPRÓ→COMPRO, EVALUACIÓN→EVALUACION, etc.
function quitarAcentos(s) {
  return s
    .replace(/[ÁÀÂÄ]/g,'A').replace(/[ÉÈÊË]/g,'E')
    .replace(/[ÍÌÎÏ]/g,'I').replace(/[ÓÒÔÖ]/g,'O')
    .replace(/[ÚÙÛÜ]/g,'U').replace(/Ñ/g,'N')
    .replace(/[áàâä]/g,'a').replace(/[éèêë]/g,'e')
    .replace(/[íìîï]/g,'i').replace(/[óòôö]/g,'o')
    .replace(/[úùûü]/g,'u').replace(/ñ/g,'n');
}
// Clave normalizada para comparar
function claveEstado(s) {
  return quitarAcentos(String(s).trim().replace(/\s+/g,' ')).toUpperCase();
}

// Mapa clave→nombre canónico
var ESTADO_CLAVE_MAP = {};
function reconstruirClaveMap() {
  ESTADO_CLAVE_MAP = {};
  ESTADOS.forEach(function(e) { ESTADO_CLAVE_MAP[claveEstado(e.v)] = e.v; });
}
reconstruirClaveMap();

function normalizarEstado(raw) {
  if (!raw || String(raw).trim() === '') return 'SIN AVANCE';
  var clave = claveEstado(raw);

  // 1. Match exacto sin acentos
  if (ESTADO_CLAVE_MAP[clave]) return ESTADO_CLAVE_MAP[clave];

  // 2. Match parcial
  for (var i = 0; i < ESTADOS.length; i++) {
    var ck = claveEstado(ESTADOS[i].v);
    if (ck.indexOf(clave) !== -1 || clave.indexOf(ck) !== -1) return ESTADOS[i].v;
  }

  // 3. Estado desconocido: registrar dinámicamente con color automático
  if (!ESTADO_MAP[clave]) {
    var colorIdx = Object.keys(ESTADO_MAP).length % COLORES_EXTRA.length;
    var nuevo = {
      v: clave,
      cls: 'bs-dyn-' + Object.keys(ESTADO_MAP).length,
      color: COLORES_EXTRA[colorIdx],
      dinamico: true
    };
    ESTADOS.push(nuevo);
    reconstruirEstadoMap();
    reconstruirClaveMap();
    // Inyectar CSS para el nuevo badge
    var styleEl = document.getElementById('dyn-css') || (function(){
      var s = document.createElement('style');
      s.id = 'dyn-css';
      document.head.appendChild(s);
      return s;
    })();
    styleEl.textContent += '.' + nuevo.cls + '{background:' + nuevo.color + '22;color:' + nuevo.color + '}\n';
  }
  return clave;
}

// ═══════════════════════════════════════════════════
//  AGRUPACIÓN
// ═══════════════════════════════════════════════════
function agrupar(rows) {
  rawEstadosMuestra = [];
  var mapa = {};
  for (var i = 0; i < rows.length; i++) {
    var r = rows[i];
    if (!r['HOSPITAL'] || String(r['HOSPITAL']).indexOf('CANTIDAD') === 0) continue;

    // Debug: guardar muestra de valores raw de ESTADO
    if (rawEstadosMuestra.length < 30 && r['ESTADO'] !== undefined) {
      var rawV = r['ESTADO'];
      rawEstadosMuestra.push({
        raw: JSON.stringify(rawV),
        norm: normalizarEstado(rawV),
        hosp: r['HOSPITAL']
      });
    }

    var key = r['HOSPITAL']+'|||'+r['EQUIPO']+'|||'+r['TIPO']+'|||'+(r['NOMBRE PROYECTO']||'');
    if (!mapa[key]) {
      mapa[key] = {
        hospital:       r['HOSPITAL'],
        equipo:         r['EQUIPO'],
        tipo:           r['TIPO'],
        q_total:        0,
        p_unit:         r['P. UNIT'],
        p_total:        0,
        chequeado:      r['CHEQUEADO CON SP'],
        tipo_proyecto:  r['TIPO PROYECTO'],
        anio_entrega:   r['AÑO ENTREGA'],
        nombre_proyecto:r['NOMBRE PROYECTO'],
        estado:         'SIN AVANCE',
        estado_orden:   0,
        expediente:     '',
        licitacion:     '',
        fecha_apertura: ''
      };
    }
    var g = mapa[key];
    g.q_total += (parseInt(r['Q SOLICIT.']) || 0);
    g.p_total += parseUSD(r['P. TOTAL']);

    // Tomar el estado más avanzado del grupo
    var e    = normalizarEstado(r['ESTADO']);
    var eIdx = -1;
    for (var j = 0; j < ESTADOS.length; j++) { if (ESTADOS[j].v === e) { eIdx = j; break; } }
    if (eIdx > g.estado_orden) { g.estado = e; g.estado_orden = eIdx; }

    if (r['FECHA DE APERTURA'] && !g.fecha_apertura) g.fecha_apertura = r['FECHA DE APERTURA'];
    if (r['EXPEDIENTE']        && !g.expediente)     g.expediente     = r['EXPEDIENTE'];
    if (r['LICITACION']        && !g.licitacion)     g.licitacion     = r['LICITACION'];
    if (r['AÑO ENTREGA']       && !g.anio_entrega)   g.anio_entrega   = r['AÑO ENTREGA'];
  }
  var result = [];
  for (var k in mapa) result.push(mapa[k]);
  return result;
}

// ═══════════════════════════════════════════════════
//  CARGA DE DATOS — JSONP + anti-caché agresivo
// ═══════════════════════════════════════════════════
function cargarDatos(manual) {
  var dot  = document.getElementById('sync-dot');
  var lbl  = document.getElementById('sync-label');
  var btn  = document.getElementById('sync-btn');
  dot.className = 'sync-dot syncing';
  lbl.textContent = 'Cargando…';
  btn.disabled = true;

  var cbName = 'gcb_' + Date.now() + '_' + Math.random().toString(36).slice(2);
  var script  = document.createElement('script');
  var done    = false;

  var timeout = setTimeout(function() {
    if (done) return;
    done = true;
    cleanup();
    dot.className  = 'sync-dot error';
    lbl.textContent = 'Error — reintentar';
    btn.disabled = false;
    if (!agrupados.length) {
      document.getElementById('loading-screen').innerHTML =
        '<div style="text-align:center"><p style="color:#E24B4A;font-weight:500;margin-bottom:12px">No se pudo conectar con Google Sheets</p>'
        +'<button onclick="cargarDatos(true)" style="font-family:inherit;padding:7px 18px;font-size:13px;border:1px solid var(--border2);border-radius:8px;background:var(--surface);cursor:pointer">Reintentar</button></div>';
    }
  }, 12000);

  function cleanup() {
    clearTimeout(timeout);
    delete window[cbName];
    if (script.parentNode) script.parentNode.removeChild(script);
  }

  window[cbName] = function(rows) {
    if (done) return;
    done = true;
    cleanup();

    rawCount = rows.filter(function(r) {
      return r['HOSPITAL'] && String(r['HOSPITAL']).indexOf('CANTIDAD') !== 0;
    }).length;

    agrupados = agrupar(rows);

    // UI
    dot.className   = 'sync-dot';
    var now = new Date().toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'});
    lbl.textContent = 'Actualizado ' + now;
    btn.disabled = false;

    document.getElementById('header-count').textContent =
      agrupados.length + ' equipos · ' + rawCount + ' filas';

    document.getElementById('loading-screen').style.display = 'none';
    document.getElementById('app').style.display = '';

    renderDash();
    renderFiltros();

    // Mostrar debug en tab equipos
    mostrarDebugEstados();
  };

  script.onerror = function() {
    if (done) return;
    done = true;
    cleanup();
    dot.className   = 'sync-dot error';
    lbl.textContent = 'Error — reintentar';
    btn.disabled = false;
  };

  // Anti-caché: timestamp + random + param ts que el script puede leer
  var bust = Date.now();
  script.src = API_URL + '?callback=' + cbName + '&nocache=' + bust + '&ts=' + bust;
  document.head.appendChild(script);
}

// ═══════════════════════════════════════════════════
//  DEBUG: mostrar valores raw de ESTADO
// ═══════════════════════════════════════════════════
function mostrarDebugEstados() {
  var panel = document.getElementById('debug-estados');
  var content = document.getElementById('debug-content');
  if (!rawEstadosMuestra.length) return;
  panel.style.display = '';

  // Contar cuántos cayeron en SIN AVANCE por no ser válidos
  var enFallback = 0;
  for (var i = 0; i < agrupados.length; i++) {
    if (agrupados[i].estado === 'SIN AVANCE') enFallback++;
  }

  var rows = rawEstadosMuestra.slice(0, 15).map(function(m) {
    var ok = m.norm !== 'SIN AVANCE' || m.raw === '"SIN AVANCE"' || m.raw === '""';
    return '<div style="margin-bottom:2px">'
      + (ok ? '✓' : '⚠') + '  raw=<span class="debug-val">'+m.raw+'</span>'
      + '  →  <span class="debug-val">'+m.norm+'</span>'
      + '  <span style="color:var(--t3)">('+m.hosp+')</span></div>';
  }).join('');

  content.innerHTML =
    '<div style="margin-bottom:8px">Equipos con estado <b>SIN AVANCE</b>: <span class="debug-val">'+enFallback+'</span> de '+agrupados.length+'</div>'
    + '<div style="margin-bottom:6px;color:var(--t3)">Muestra de valores leídos de la columna ESTADO (primeras 15 filas):</div>'
    + rows
    + '<div style="margin-top:8px;color:var(--t3)">Si ves ⚠ con raw distinto al estado esperado, verificá el nombre exacto de la columna en el Sheet.</div>';
}

// ═══════════════════════════════════════════════════
//  TABS
// ═══════════════════════════════════════════════════
function showTab(t) {
  var all = ['dashboard','proyectos','equipos','distribucion'];
  all.forEach(function(id) {
    document.getElementById('tab-'+id).style.display = id === t ? '' : 'none';
  });
  document.querySelectorAll('.tab').forEach(function(el, i) {
    el.classList.toggle('active', all[i] === t);
  });
  if (t === 'dashboard')    renderDash();
  if (t === 'proyectos')    renderProyectos();
  if (t === 'equipos')      renderTabla();
  if (t === 'distribucion') renderDistribucion();
}

// ═══════════════════════════════════════════════════
//  DASHBOARD
// ═══════════════════════════════════════════════════
function renderDash() {
  var total = agrupados.length; if (!total) return;
  var conAp = 0, cheq = 0, hospsSet = {}, totalUSD = 0;
  agrupados.forEach(function(d) {
    if (d.fecha_apertura) conAp++;
    if (d.chequeado === 'TRUE') cheq++;
    hospsSet[d.hospital] = 1;
    totalUSD += d.p_total;
  });

  document.getElementById('metrics').innerHTML =
    metric('Equipos únicos', total, rawCount + ' filas en Sheet') +
    metric('Hospitales', Object.keys(hospsSet).length, '') +
    metric('Monto estimado', fmtUSD(totalUSD), '', true) +
    metric('Con fecha apertura', conAp, Math.round(conAp/total*100)+'% del total') +
    metric('Chequeados con SP', cheq, Math.round(cheq/total*100)+'% del total');

  function metric(label, val, sub, small) {
    return '<div class="metric"><div class="metric-label">'+label+'</div>'
      + '<div class="metric-value" style="'+(small?'font-size:16px':'')+'">'+val+'</div>'
      + (sub ? '<div class="metric-sub">'+sub+'</div>' : '')
      + '</div>';
  }

  // Contar por estado
  var counts = {};
  ESTADOS.forEach(function(e) { counts[e.v] = 0; });
  agrupados.forEach(function(d) { counts[d.estado] = (counts[d.estado]||0) + 1; });

  var genHTML = '', legendHTML = '', progHTML = '';
  ESTADOS.forEach(function(est) {
    var c = counts[est.v] || 0;
    var pct = Math.round(c / total * 100);
    genHTML += '<div class="prog-seg" style="width:'+pct+'%;background:'+est.color+'" title="'+est.v+': '+c+' ('+pct+'%)"></div>';
    legendHTML += '<div class="prog-legend-item"><div class="prog-dot" style="background:'+est.color+'"></div><span>'+est.v+' ('+c+')</span></div>';
    progHTML += '<div class="prog-single">'
      + '<div class="prog-header"><span class="prog-name">'+est.v+'</span>'
      + '<span class="prog-pct">'+c+' · '+pct+'%</span></div>'
      + '<div class="prog-track"><div class="prog-fill" style="width:'+pct+'%;background:'+est.color+'"></div></div>'
      + '</div>';
  });
  document.getElementById('prog-gen').innerHTML    = genHTML;
  document.getElementById('prog-legend').innerHTML = legendHTML;
  document.getElementById('prog-estados').innerHTML = progHTML;

  // Hospitales
  var hospC = {};
  agrupados.forEach(function(d) { hospC[d.hospital] = (hospC[d.hospital]||0)+1; });
  var top10 = Object.entries(hospC).sort(function(a,b){return b[1]-a[1];}).slice(0,10);
  barChart('ch-hosp', Object.fromEntries(top10), function() { return '#7C74E8'; });

  // Tipos
  var tipoC = {};
  agrupados.forEach(function(d) { if (d.tipo_proyecto) tipoC[d.tipo_proyecto] = (tipoC[d.tipo_proyecto]||0)+1; });
  barChart('ch-tipo', tipoC, function(k) { return TIPO_COLOR[k] || '#9B9890'; });

  // Próximas aperturas
  var hoy = new Date(); hoy.setHours(0,0,0,0);
  var prox = agrupados
    .filter(function(d) { return d.fecha_apertura; })
    .map(function(d) { return { d:d, diff: Math.ceil((new Date(d.fecha_apertura+'T00:00:00')-hoy)/86400000) }; })
    .sort(function(a,b) { return a.diff-b.diff; })
    .slice(0,10);

  var apEl = document.getElementById('ch-apertura');
  if (!prox.length) {
    apEl.innerHTML = '<div style="color:var(--t3);font-size:13px;padding:8px">Ningún equipo tiene fecha de apertura cargada.</div>';
  } else {
    var rows = prox.map(function(p) {
      var d = p.d;
      return '<tr>'
        +'<td style="font-weight:600">'+d.hospital+'</td>'
        +'<td>'+d.equipo+'</td>'
        +'<td style="color:var(--t2)">'+(d.nombre_proyecto||'—')+'</td>'
        +'<td style="color:var(--t3);font-family:DM Mono,monospace;font-size:11px">'+(d.expediente||'—')+'</td>'
        +'<td style="white-space:nowrap;font-family:DM Mono,monospace;font-size:12px">'+fmtFecha(d.fecha_apertura)+'</td>'
        +'<td>'+badge(d.estado)+'</td>'
        +'<td>'+diasChip(d.fecha_apertura)+'</td>'
        +'</tr>';
    }).join('');
    apEl.innerHTML = '<table class="urg-table"><thead><tr><th>Hospital</th><th>Equipo</th><th>Proyecto</th><th>Expediente</th><th>Fecha</th><th>Estado</th><th>Días</th></tr></thead><tbody>'+rows+'</tbody></table>';
  }
}

function barChart(id, counts, colorFn) {
  var el = document.getElementById(id); if (!el) return;
  var entries = Object.entries(counts).sort(function(a,b){return b[1]-a[1];});
  var max = entries.reduce(function(m,e){return Math.max(m,e[1]);}, 1);
  el.innerHTML = entries.map(function(e) {
    var k=e[0],v=e[1];
    return '<div class="bar-row">'
      +'<div class="bar-label" title="'+k+'">'+k+'</div>'
      +'<div class="bar-track"><div class="bar-fill" style="width:'+Math.round(v/max*100)+'%;background:'+colorFn(k)+'"></div></div>'
      +'<div class="bar-count">'+v+'</div>'
      +'</div>';
  }).join('');
}

// ═══════════════════════════════════════════════════
//  PROYECTOS
// ═══════════════════════════════════════════════════
function renderProyectos() {
  var grupos = {};
  agrupados.forEach(function(d) {
    var k = d.nombre_proyecto || '(sin proyecto)';
    if (!grupos[k]) grupos[k] = [];
    grupos[k].push(d);
  });
  var sorted = Object.entries(grupos).sort(function(a,b){return b[1].length-a[1].length;});
  var totalGral = agrupados.reduce(function(s,d){return s+d.p_total;}, 0);
  document.getElementById('proy-total').textContent =
    'Total: ' + fmtUSD(totalGral) + ' · ' + sorted.length + ' proyectos';

  var html = sorted.map(function(entry, idx) {
    var nombre = entry[0], items = entry[1];
    var monto = items.reduce(function(s,d){return s+d.p_total;},0);
    var hosps = Object.keys(items.reduce(function(h,d){h[d.hospital]=1;return h;},{})).sort().join(', ');
    var estados = items.reduce(function(m,d){m[d.estado]=(m[d.estado]||0)+1;return m;},{});
    var badgesHTML = Object.entries(estados).map(function(e){
      return badge(e[0])+'<span style="font-size:10px;color:var(--t3);margin-left:2px">×'+e[1]+'</span>';
    }).join(' ');
    var rowsHTML = items.map(function(d) {
      return '<tr>'
        +'<td style="font-weight:600">'+d.hospital+'</td>'
        +'<td>'+d.equipo+'</td>'
        +'<td style="color:var(--t2)">'+(d.tipo||'—')+'</td>'
        +'<td style="text-align:center;font-weight:600">'+(d.q_total||'—')+'</td>'
        +'<td style="white-space:nowrap;font-family:DM Mono,monospace;font-size:11px">'+fmtUSD(d.p_total)+'</td>'
        +'<td style="white-space:nowrap;font-family:DM Mono,monospace;font-size:11px">'+fmtFecha(d.fecha_apertura)+'</td>'
        +'<td>'+diasChip(d.fecha_apertura)+'</td>'
        +'<td>'+badge(d.estado)+'</td>'
        +'</tr>';
    }).join('');
    return '<div class="proy-card">'
      +'<div class="proy-header" onclick="toggleProy('+idx+')">'
        +'<div style="flex:1"><div class="proy-name">'+nombre+'</div>'
        +'<div class="proy-hospitals">'+hosps+'</div>'
        +'<div class="proy-badges">'+badgesHTML+'</div></div>'
        +'<div class="proy-meta">'
          +'<span class="proy-count">'+items.length+' equipos</span>'
          +'<span class="proy-monto">'+fmtUSD(monto)+'</span>'
          +'<span class="proy-arrow" id="arrow-'+idx+'">▶</span>'
        +'</div>'
      +'</div>'
      +'<div class="proy-body" id="proy-body-'+idx+'">'
        +'<table class="proy-table"><thead><tr><th>Hospital</th><th>Equipo</th><th>Tipo</th><th>Q</th><th>P. Total</th><th>Apertura</th><th>Días</th><th>Estado</th></tr></thead>'
        +'<tbody>'+rowsHTML+'</tbody></table>'
      +'</div>'
      +'</div>';
  }).join('');
  document.getElementById('proy-container').innerHTML = html;
}

function toggleProy(idx) {
  document.getElementById('proy-body-'+idx).classList.toggle('open');
  document.getElementById('arrow-'+idx).classList.toggle('open');
}

// ═══════════════════════════════════════════════════
//  MULTI-SELECT ENGINE
// ═══════════════════════════════════════════════════

// Almacena selecciones: { estado: Set, hosp: Set, tipo: Set, proy: Set, lic: Set, anio: Set }
var MS = { estado: new Set(), hosp: new Set(), tipo: new Set(), proy: new Set(), lic: new Set(), anio: new Set() };

var MS_CFG = {
  estado: { label: 'Estado',       field: function(d){ return d.estado; } },
  hosp:   { label: 'Hospital',     field: function(d){ return d.hospital; } },
  tipo:   { label: 'Tipo proyecto',field: function(d){ return d.tipo_proyecto; } },
  proy:   { label: 'Proyecto',     field: function(d){ return d.nombre_proyecto; } },
  lic:    { label: 'Licitación',   field: function(d){ return d.licitacion; } },
  anio:   { label: 'Año entrega',  field: function(d){ return d.anio_entrega; } }
};

function buildMsPanel(key, values) {
  var panel = document.getElementById('ms-panel-' + key);
  panel.innerHTML = '';
  if (!values.length) { panel.innerHTML = '<div style="padding:10px 12px;font-size:12px;color:var(--t3)">Sin opciones</div>'; return; }
  var clearEl = document.createElement('div');
  clearEl.className = 'ms-clear';
  clearEl.textContent = 'Limpiar selección';
  clearEl.onclick = function(e) { e.stopPropagation(); MS[key].clear(); refreshMsUI(key); renderTabla(); };
  panel.appendChild(clearEl);
  var sep = document.createElement('div'); sep.className = 'ms-sep'; panel.appendChild(sep);
  values.forEach(function(v) {
    var item = document.createElement('div'); item.className = 'ms-item';
    var cb = document.createElement('input'); cb.type = 'checkbox'; cb.id = 'ms-'+key+'-'+v;
    cb.checked = MS[key].has(v);
    cb.onchange = function(e) { e.stopPropagation(); if(this.checked) MS[key].add(v); else MS[key].delete(v); refreshMsUI(key); renderTabla(); };
    var lbl = document.createElement('label'); lbl.htmlFor = cb.id; lbl.textContent = v || '(vacío)';
    item.appendChild(cb); item.appendChild(lbl);
    item.onclick = function(e) { if(e.target !== cb) cb.click(); };
    panel.appendChild(item);
  });
}

function refreshMsUI(key) {
  var n = MS[key].size;
  var btn = document.getElementById('ms-btn-' + key);
  var cnt = document.getElementById('ms-cnt-' + key);
  cnt.style.display = n ? '' : 'none';
  cnt.textContent = n;
  btn.classList.toggle('has-sel', n > 0);
  // sync checkboxes
  var panel = document.getElementById('ms-panel-' + key);
  panel.querySelectorAll('input[type=checkbox]').forEach(function(cb) {
    var v = cb.id.replace('ms-'+key+'-', '');
    cb.checked = MS[key].has(v);
  });
  renderChips();
}

function renderChips() {
  var chips = document.getElementById('active-chips');
  if (!chips) return;
  var html = '';
  Object.keys(MS_CFG).forEach(function(key) {
    MS[key].forEach(function(v) {
      html += '<span class="active-chip">'
        + MS_CFG[key].label + ': ' + (v||'(vacío)')
        + ' <span class="chip-x" onclick="removeChip(''+key+'',''+v.replace(/'/g,"\'")+'')">&times;</span>'
        + '</span>';
    });
  });
  chips.innerHTML = html;
}

function removeChip(key, v) {
  MS[key].delete(v);
  refreshMsUI(key);
  renderTabla();
}

function limpiarFiltros() {
  Object.keys(MS).forEach(function(k) { MS[k].clear(); refreshMsUI(k); });
  document.getElementById('search').value = '';
  renderTabla();
}

function toggleMs(key, e) {
  e.stopPropagation();
  var panel = document.getElementById('ms-panel-' + key);
  var isOpen = panel.classList.contains('open');
  // close all
  document.querySelectorAll('.ms-panel').forEach(function(p){ p.classList.remove('open'); });
  if (!isOpen) panel.classList.add('open');
}

// Close all panels on outside click
document.addEventListener('click', function() {
  document.querySelectorAll('.ms-panel').forEach(function(p){ p.classList.remove('open'); });
});

// ═══════════════════════════════════════════════════
//  EQUIPOS
// ═══════════════════════════════════════════════════
function renderFiltros() {
  // Construir opciones de cada multi-select desde los datos
  var sets = { estado:new Set(), hosp:new Set(), tipo:new Set(), proy:new Set(), lic:new Set(), anio:new Set() };
  agrupados.forEach(function(d) {
    if (d.estado)         sets.estado.add(d.estado);
    if (d.hospital)       sets.hosp.add(d.hospital);
    if (d.tipo_proyecto)  sets.tipo.add(d.tipo_proyecto);
    if (d.nombre_proyecto)sets.proy.add(d.nombre_proyecto);
    if (d.licitacion)     sets.lic.add(d.licitacion);
    if (d.anio_entrega)   sets.anio.add(d.anio_entrega);
  });
  // Estados en orden de avance, el resto alfabético
  var estadoVals = ESTADOS.map(function(e){return e.v;}).filter(function(v){return sets.estado.has(v);});
  buildMsPanel('estado', estadoVals);
  buildMsPanel('hosp',   Array.from(sets.hosp).sort());
  buildMsPanel('tipo',   Array.from(sets.tipo).sort());
  buildMsPanel('proy',   Array.from(sets.proy).sort());
  buildMsPanel('lic',    Array.from(sets.lic).sort());
  buildMsPanel('anio',   Array.from(sets.anio).sort());
}

function renderTabla() {
  var q = (document.getElementById('search').value||'').toLowerCase();

  var filtered = agrupados.filter(function(d) {
    if (MS.estado.size && !MS.estado.has(d.estado))        return false;
    if (MS.hosp.size   && !MS.hosp.has(d.hospital))        return false;
    if (MS.tipo.size   && !MS.tipo.has(d.tipo_proyecto))   return false;
    if (MS.proy.size   && !MS.proy.has(d.nombre_proyecto)) return false;
    if (MS.lic.size    && !MS.lic.has(d.licitacion))       return false;
    if (MS.anio.size   && !MS.anio.has(d.anio_entrega))    return false;
    if (q) {
      var txt = (d.hospital+d.equipo+d.tipo+d.nombre_proyecto+d.expediente+d.licitacion).toLowerCase();
      if (txt.indexOf(q) === -1) return false;
    }
    return true;
  });

  var totalF = filtered.reduce(function(s,d){return s+d.p_total;},0);
  var totalG = agrupados.reduce(function(s,d){return s+d.p_total;},0);

  document.getElementById('total-bar').innerHTML =
    '<span class="total-label">Total visible:</span>'
    +'<span class="total-value">'+fmtUSD(totalF)+'</span>'
    +'<span class="total-sub">de '+fmtUSD(totalG)+' total · '+filtered.length+' de '+agrupados.length+' equipos</span>';

  var tbody = document.getElementById('tbody');
  var empty = document.getElementById('empty');
  if (!filtered.length) { tbody.innerHTML = ''; empty.style.display = ''; return; }
  empty.style.display = 'none';

  tbody.innerHTML = filtered.map(function(d) {
    return '<tr>'
      +'<td style="font-weight:600">'+d.hospital+'</td>'
      +'<td>'+d.equipo+'</td>'
      +'<td style="color:var(--t2)">'+(d.tipo||'—')+'</td>'
      +'<td style="text-align:center;font-weight:600">'+(d.q_total||'—')+'</td>'
      +'<td style="white-space:nowrap;font-size:11px;color:var(--t2)">'+(d.p_unit||'—')+'</td>'
      +'<td style="white-space:nowrap;font-family:DM Mono,monospace;font-size:11px">'+fmtUSD(d.p_total)+'</td>'
      +'<td style="color:var(--t2);max-width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="'+(d.nombre_proyecto||'')+'">'+(d.nombre_proyecto||'—')+'</td>'
      +'<td>'+(d.tipo_proyecto||'—')+'</td>'
      +'<td style="color:var(--t3);text-align:center;font-family:DM Mono,monospace;font-size:11px">'+(d.anio_entrega||'—')+'</td>'
      +'<td style="color:var(--t3);font-size:11px;font-family:DM Mono,monospace">'+(d.expediente||'—')+'</td>'
      +'<td style="color:var(--t3);font-size:11px;font-family:DM Mono,monospace">'+(d.licitacion||'—')+'</td>'
      +'<td style="white-space:nowrap;font-size:11px">'+fmtFecha(d.fecha_apertura)+' '+diasChip(d.fecha_apertura)+'</td>'
      +'<td>'+badge(d.estado)+'</td>'
      +'<td><span class="tag-cheq '+(d.chequeado==='TRUE'?'tag-si':'tag-no')+'">'+(d.chequeado==='TRUE'?'Sí':'No')+'</span></td>'
      +'</tr>';
  }).join('');

  document.getElementById('tfoot').textContent =
    'Mostrando ' + filtered.length + ' de ' + agrupados.length + ' equipos únicos';
}

// ═══════════════════════════════════════════════════
//  DISTRIBUCIÓN DE EQUIPOS
// ═══════════════════════════════════════════════════
function renderDistribucion() {
  var q = (document.getElementById('dist-search').value||'').toLowerCase();

  // Agrupar por nombre de equipo (normalizado)
  var grupos = {};
  agrupados.forEach(function(d) {
    var key = (d.equipo||'').trim().toUpperCase();
    if (!key) return;
    if (!grupos[key]) grupos[key] = { nombre: d.equipo, items: [] };
    grupos[key].items.push(d);
  });

  // Filtrar por búsqueda
  var lista = Object.values(grupos).filter(function(g) {
    return !q || g.nombre.toLowerCase().indexOf(q) !== -1;
  });

  // Ordenar por cantidad total descendente
  lista.sort(function(a,b) {
    var qa = a.items.reduce(function(s,d){return s+d.q_total;},0);
    var qb = b.items.reduce(function(s,d){return s+d.q_total;},0);
    return qb - qa;
  });

  var totalEquipos = lista.length;
  var totalUnidades = lista.reduce(function(s,g){return s+g.items.reduce(function(ss,d){return ss+d.q_total;},0);},0);
  document.getElementById('dist-total').textContent =
    totalEquipos + ' tipos de equipo · ' + totalUnidades + ' unidades totales';

  if (!lista.length) {
    document.getElementById('dist-container').innerHTML =
      '<div class="empty">Sin resultados.</div>';
    return;
  }

  var html = lista.map(function(g, idx) {
    var items = g.items;
    var qtotal = items.reduce(function(s,d){return s+d.q_total;},0);
    var mtotal = items.reduce(function(s,d){return s+d.p_total;},0);
    var hosps  = items.length; // un item por hospital (ya agrupado)

    // Agrupar ítems por hospital y sumar si hay más de uno igual
    var porHosp = {};
    items.forEach(function(d) {
      var hk = d.hospital;
      if (!porHosp[hk]) porHosp[hk] = { hospital: d.hospital, q: 0, monto: 0, estado: d.estado, proyecto: d.nombre_proyecto, licitacion: d.licitacion };
      porHosp[hk].q     += d.q_total;
      porHosp[hk].monto += d.p_total;
    });
    var filas = Object.values(porHosp).sort(function(a,b){return b.q-a.q;});

    var rowsHTML = filas.map(function(f) {
      return '<tr>'
        +'<td style="font-weight:600">'+f.hospital+'</td>'
        +'<td class="dist-qty-cell">'+f.q+'</td>'
        +'<td style="font-family:DM Mono,monospace;font-size:11px">'+fmtUSD(f.monto)+'</td>'
        +'<td>'+badge(f.estado)+'</td>'
        +'<td style="color:var(--t2);font-size:11px;max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="'+(f.proyecto||'')+'">'+( f.proyecto||'—')+'</td>'
        +'<td style="color:var(--t3);font-size:11px;font-family:DM Mono,monospace">'+(f.licitacion||'—')+'</td>'
        +'</tr>';
    }).join('');

    return '<div class="dist-card">'
      +'<div class="dist-header" onclick="toggleDist('+idx+')">'
        +'<div class="dist-name">'+g.nombre+'</div>'
        +'<div class="dist-meta">'
          +'<span class="dist-hosp-count">'+hosps+' hospital'+(hosps!==1?'es':'')+'</span>'
          +'<span class="dist-qty">'+qtotal+' ud.</span>'
          +'<span class="dist-monto">'+fmtUSD(mtotal)+'</span>'
          +'<span class="proy-arrow" id="dist-arrow-'+idx+'">▶</span>'
        +'</div>'
      +'</div>'
      +'<div class="dist-body" id="dist-body-'+idx+'">'
        +'<table class="dist-table">'
          +'<thead><tr><th>Hospital</th><th>Cantidad</th><th>Monto</th><th>Estado</th><th>Proyecto</th><th>Licitación</th></tr></thead>'
          +'<tbody>'+rowsHTML+'</tbody>'
        +'</table>'
      +'</div>'
      +'</div>';
  }).join('');

  document.getElementById('dist-container').innerHTML = html;
}

function toggleDist(idx) {
  document.getElementById('dist-body-'+idx).classList.toggle('open');
  document.getElementById('dist-arrow-'+idx).classList.toggle('open');
}

